# Copy to .env (or set in the environment) before running the service.

# Postgres connection (reuse the docker-compose Postgres from the repo root).
DATABASE_URL=postgresql+psycopg://screensmart:screensmart@localhost:5432/screensmart

# --- Service knobs (all optional; prefix SANCTIONS_INGEST_) -------------------
# Hour of day (0-23, server local time) for the daily ingest. Default 3 (03:00).
SANCTIONS_INGEST_INGEST_HOUR=3
# Minute of the hour. Default 0.
SANCTIONS_INGEST_INGEST_MINUTE=0
# Run one ingest immediately on scheduler startup if the DB looks empty.
SANCTIONS_INGEST_RUN_ON_STARTUP=true
# HTTP timeout (seconds) per source download.
SANCTIONS_INGEST_HTTP_TIMEOUT=120
# Override where raw downloaded files are written (defaults to <repo>/data/raw).
# SANCTIONS_INGEST_RAW_DIR=C:\path\to\data\raw
