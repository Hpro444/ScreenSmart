# Copy to `.env` before `docker compose up` (compose interpolates these).
POSTGRES_DB=screensmart
POSTGRES_USER=screensmart
POSTGRES_PASSWORD=screensmart
POSTGRES_PORT=5432
POSTGRES_CONTAINER_NAME=screensmart-postgres

# ws-gateway analyst login + token signing (change for anything real)
JWT_SECRET=dev-screensmart-secret-change-me
ANALYST_USER=analyst
ANALYST_PASSWORD=analyst
