# Copy to .env and fill in your values.
# The DATABASE_URL uses the psycopg3 driver scheme (postgresql+psycopg://).

DATABASE_URL=postgresql+psycopg://screensmart:screensmart@localhost:5432/screensmart

# Individual components used by docker-compose.yml
POSTGRES_USER=screensmart
POSTGRES_PASSWORD=screensmart
POSTGRES_DB=screensmart
POSTGRES_PORT=5432
